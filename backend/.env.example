# =====================
# SP Customs Backend Environment Variables
# =====================
# Copy this file to .env and update the values

# Application
APP_NAME="SP Customs - Vehicle Gadgets Platform"
APP_VERSION="1.0.0"
DEBUG=true
ENABLE_API_DOCS=true

# Database (PostgreSQL)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=
DATABASE_URL_SYNC=

# Security
# IMPORTANT: Change this to a secure random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Admin Credentials (Initial Setup)
# Change these after first login!
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Image Storage
# Options: "database" (stores in PostgreSQL) or "s3" (AWS S3)
IMAGE_STORAGE_TYPE=database
MAX_IMAGE_SIZE_MB=10
IMAGE_QUALITY=85

# AWS S3 Configuration (only needed if IMAGE_STORAGE_TYPE=s3)
# S3_BUCKET_NAME=
# S3_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Shiprocket (API only; no dashboard dependency)
# Get credentials from Shiprocket Settings > API > Create API User
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
# SHIPROCKET_PICKUP_PINCODE=110001
# SHIPROCKET_SHIPPING_WEBHOOK_TOKEN=

# Book Now / checkout flow (set false to disable)
ENABLE_BOOK_NOW=true

# Customer OTP: WhatsApp (Meta Cloud API) if WHATSAPP_* set; else dummy OTP for dev.
OTP_DUMMY_FOR_DEV=true
OTP_DUMMY_CODE=123456
# WhatsApp — template names must match Meta Business Manager
# Callback URL for webhooks: {PUBLIC_BASE_URL}/api/webhooks/whatsapp (GET verify + POST events)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_GRAPH_API_VERSION=v21.0
# WHATSAPP_OTP_TEMPLATE_NAME=otp_login
# OTP template language (otp_login · English US → en_US)
# WHATSAPP_TEMPLATE_LANGUAGE=en_US
# WHATSAPP_OTP_TEMPLATE_HAS_URL_BUTTON=false
# WHATSAPP_OTP_URL_BUTTON_USE_BODY_OTP=true
# WHATSAPP_OTP_URL_BUTTON_PARAM=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
# New-order WhatsApp (same WHATSAPP_ACCESS_TOKEN / WHATSAPP_PHONE_NUMBER_ID as OTP)
# WHATSAPP_ORDER_NOTIFY_PHONE=
# Order templates language (order_alert / order_confirmed · English → en)
# WHATSAPP_ORDER_TEMPLATE_LANGUAGE=en
# WHATSAPP_ORDER_TEMPLATE_NAME=order_alert
# WHATSAPP_ORDER_CUSTOMER_TEMPLATE_NAME=order_confirmed

# Store settings (admin-managed): customer discount % and order status list (comma-separated)
CUSTOMER_DISCOUNT_PERCENT=10
ORDER_STATUS_LIST="Pending Approval,Processing,Packed,Shipped,Out for Delivery,Delivered,Cancelled"

# Shiprocket SR Checkout (payment)
SHIPROCKET_CHECKOUT_ENABLED=false
SHIPROCKET_CHECKOUT_API_KEY=
SHIPROCKET_CHECKOUT_SECRET_KEY=
SHIPROCKET_CHECKOUT_TOKEN_URL=https://checkout-api.shiprocket.com/api/v1/access-token/checkout
SHIPROCKET_CHECKOUT_SESSION_URL=https://checkout-api.shiprocket.com/public-api/v1/checkout/session
# SHIPROCKET_CHECKOUT_WEBHOOK_SECRET=

FRONTEND_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:8000

# Razorpay Checkout
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR
RAZORPAY_COMPANY_NAME="SP Customs"
RAZORPAY_WEBHOOK_SECRET=
